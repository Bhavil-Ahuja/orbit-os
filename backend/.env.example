# Copy this file to .env and fill in your values.
# .env is gitignored — do not commit real secrets.

# Database — use EITHER a database URL OR the three SPRING_DATASOURCE_* vars below.
# For Railway Postgres when running LOCALLY: use DATABASE_PUBLIC_URL (not DATABASE_URL — the private URL uses postgres.railway.internal and only works inside Railway).
# DATABASE_PUBLIC_URL=postgresql://user:password@containers-us-west-xxx.railway.app:5432/railway
# When deployed ON Railway: Railway sets DATABASE_URL (private) and the app uses it automatically.
# Or for local Docker:
# SPRING_DATASOURCE_PASSWORD=postgres
# SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=
SPRING_DATASOURCE_USERNAME=postgres

# Admin (dev: plain password for login; production: use ADMIN_PASSWORD_HASH and ADMIN_JWT_SECRET)
ADMIN_PASSWORD=your-admin-password
ADMIN_JWT_SECRET=your-jwt-secret-min-32-characters

# CORS: optional comma-separated origins for deployed frontend (localhost:3000, 5173 always allowed)
# APP_CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Cloudinary (for resume PDF upload in admin)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
